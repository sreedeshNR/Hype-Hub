<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Addresses - HypeHub</title>
  <link rel="stylesheet" href="/css/profile.css"/>
</head>
<body>

  <div class="profile-container">
    <%- include('../partials/sidebar') %>

    <div class="profile-main">

      <% if (success){ %>
        <div class="success-msg" id="successMsg"> <%= success  %></div>
        <% } %>

      <div class="page-header">
        <div>
          <h2 class="page-title">Saved Addresses</h2>
          <p class="page-subtitle">Manage your shipping destinations.</p>
        </div>
        <a href="/addresses/add" class="btn-primary">+ ADD NEW ADDRESS</a>
      </div>

      <% if (addresses.length === 0) { %>
        <div class="empty-state">
          <p>No addresses saved yet.</p>
          <a href="/addresses/add" class="btn-primary">Add Address</a>
        </div>
      <% } else { %>
        <div class="address-grid">
          <% addresses.forEach(address => { %>
            <div class="address-card">

              <!-- Top badges -->
              <div class="address-card-top">
                <span class="type-badge"><%= address.addressType %></span>
                <% if (address.isDefault) { %>
                  <span class="default-badge">PRIMARY</span>
                <% } %>
                <div class="address-actions">
                  <a href="/addresses/edit/<%= address._id %>">✏️</a>
                  <form action="/addresses/delete/<%= address._id %>"
                    method="POST"
                    id="delete-<%= address._id %>">
                    <button type="button" onclick="
                      CustomAlert.confirm({
                        title: 'Delete Address',
                        message: 'Are you sure you want to delete this address?',
                        confirmText: 'DELETE',
                        cancelText: 'Cancel',
                        onConfirm: () => document.getElementById('delete-<%= address._id %>').submit(),
                        onCancel: ()=> {},
                      })
                    ">🗑️</button>
                  </form>
                </div>
              </div>

              <!-- Address Info -->
              <h3><%= address.fullName %></h3>
              <p class="address-phone"><%= address.phone %></p>
              <p class="address-line">
                <%= address.addressLine %>,
                <% if (address.landmark) { %> <%= address.landmark %>, <% } %>
                <%= address.city %>, <%= address.state %> <%= address.pincode %>
              </p>

            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <script>
  const msg = document.getElementById("successMsg");
  if (msg) {
    setTimeout(() => {
      msg.style.transition = "opacity 0.5s";
      msg.style.opacity = "0";
      setTimeout(() => msg.remove(), 500);
    }, 3000);
  }
</script>
  <script src="/js/loader.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>