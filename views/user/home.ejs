<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/landing.css"/>
</head>
<body>

  <%- include('partials/navbar') %>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <span class="hero-badge">LOOKING FOR THE BEST</span>
      <h1>OWN THE <span>CULTURE.</span></h1>
      <p>The definitive marketplace for elite streetwear and rare sneaker drops. Find the culture curated for the ones who lead it.</p>
      <a href="#" class="btn-hero">SHOP NOW</a>
    </div>
    <div class="hero-image">
      <img src="/images/home/hero-shoe.png" alt="Hero Shoe"/>
    </div>
  </section>

  <!-- Trending Now -->
  <section class="trending">
    <div class="section-header">
      <h2>TRENDING NOW</h2>
      <p class="section-sub">High visibility, first to know every drop.</p>
      <a href="#" class="view-all">VIEW ALL →</a>
    </div>
    <div class="product-grid">
      <div class="product-card">
        <div class="product-img-wrap">
          <img src="/images/home/shoe1.png" alt="Product"/>
          <span class="product-tag">NEW</span>
        </div>
        <h3>AIR FORCE 1 Supreme - Blackest</h3>
        <p class="product-brand">Tactical wear, fits well</p>
        <p class="product-price">₹4999</p>
      </div>
      <div class="product-card">
        <div class="product-img-wrap">
          <img src="/images/home/shoe2.png" alt="Product"/>
          <span class="product-tag urgent">URGENT</span>
        </div>
        <h3>La Air Jordan 1 Retro High Dark Mocha est</h3>
        <p class="product-brand">Tactical wear, fits well</p>
        <p class="product-price">₹4299</p>
      </div>
      <div class="product-card">
        <div class="product-img-wrap">
          <img src="/images/home/shoe3.png" alt="Product"/>
        </div>
        <h3>Jordan 1 Retro High Dark Mocha</h3>
        <p class="product-brand">Tactical wear, fits well</p>
        <p class="product-price">₹ 3500</p>
      </div>
    </div>
  </section>

  <!-- Banner -->
  <section class="banner">
    <div class="banner-content">
      <span class="banner-tag">LEGEND</span>
      <h2>ENGINEERED <br/>FOR THE NIGHT.</h2>
      <p>Our latest capsule collection merges tactical utility with high-visibility aesthetics.</p>
      <a href="#" class="btn-hero">SHOP NOW</a>
    </div>
  </section>

  <!-- Archives -->
  <section class="archives">
    <h2>THE ARCHIVES</h2>
    <div class="archives-grid">
      <div class="archive-card">
        <img src="/images/home/archive1.png" alt="Lifestyle"/>
        <div class="archive-info">
          <h3>CASUAL</h3>
          <p>View Collection →</p>
        </div>
      </div>
      <div class="archive-card">
        <img src="/images/home/archive2.png" alt="Footwear"/>
        <div class="archive-info">
          <h3>FOOTWEAR</h3>
          <p>View Collection →</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-top">
      <div class="footer-brand">
        <h3>HypeHub</h3>
        <p>The definitive marketplace for elite streetwear and rare sneaker drops.</p>
      </div>
      <div class="footer-links">
        <div class="footer-col">
          <h4>ARTICLES</h4>
          <a href="#">Drops</a>
          <a href="#">News</a>
          <a href="#">Guides</a>
          <a href="#">Events</a>
        </div>
        <div class="footer-col">
          <h4>SUPPORT</h4>
          <a href="#">Shipping</a>
          <a href="#">Authentication</a>
          <a href="#">Contact</a>
        </div>
        <div class="footer-col">
          <h4>LINKS</h4>
          <a href="#">Privacy</a>
          <a href="#">Terms</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2024 HypeHub Marketplace. All rights reserved.</p>
    </div>
  </footer>

  <script src="/js/loader.js"></script>
  <script src="/js/main.js"></script>

</body>
</html>