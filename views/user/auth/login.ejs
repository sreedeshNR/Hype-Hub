<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login - HypeHub</title>
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body>

  <div class="auth-container">

    <!-- Left Side -->
    <div class="auth-left">
      <div class="auth-left-content">
        <h1>OWN <br/> THE <br/><span>CULTURE.</span></h1>
        <p>Secure the rarest sneaker drops, authenticate elite grails, and dominate the global secondary market.</p>
        <hr class="orange-line"/>
      </div>
    </div>

    <!-- Right Side -->
    <div class="auth-right">
<div class="auth-box">
  <div class="brand-name">HYPEHUB</div>
  <h2>Welcome Back</h2>
  <p class="subtitle">Sign in to secure your next grail.</p>

  <% if (typeof errors !== 'undefined' && errors.general) { %>
    <div class="error-msg"><%= errors.general %></div>
  <% } %>

  <% if (success) { %>
    <div class="success-msg"><%= success %></div>
  <% } %>

<form action="/login" method="POST" id="loginForm" autocomplete="off">

  <input type="text" style="display:none;" name="fakeEmail"/>
  <input type="password" style="display:none;" name="fakePassword"/>

  <div class="form-group">
    <label>EMAIL</label>
    <div class="input-icon">
      <span>✉</span>
<input
  type="email"
  name="email"
  id="email"
  autocomplete="email"
  placeholder="enter@address.com"
  value="<%= typeof formData !== 'undefined' ? formData.email || '' : '' %>"/>
    </div>
    <% if (typeof errors !== 'undefined' && errors.email) { %>
      <span class="field-error"><%= errors.email %></span>
    <% } %>
  </div>

  <div class="form-group">
    <div class="label-row">
      <label>PASSWORD</label>
      <a href="/forgot-password" class="forgot-link">Forgot?</a>
    </div>
    <div class="input-icon">
<input
  type="password"
  name="password"
  id="password"
  autocomplete="new-password"
  placeholder="••••••••"/>
      <span class="eye-icon" id="password-icon" onclick="togglePassword('password')" style="pointer-events:all; cursor:pointer;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="pointer-events:none;">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
        </svg>
      </span>
    </div>
    <% if (typeof errors !== 'undefined' && errors.password) { %>
      <span class="field-error"><%= errors.password %></span>
    <% } %>
  </div>

  <button type="submit" class="btn-primary">LOG IN →</button>

</form>

  <div class="divider">OR CONTINUE WITH</div>

  <a href="/auth/google" class="google-btn">
    <img src="/images/icons/google-icon.png" alt="Google" width="20"/>
    Google
  </a>

  <p class="redirect-text">
    New to HypeHub? <a href="/register">Create an account</a>
  </p>

  <p class="copyright">© 2024 HYPEHUB MARKETPLACE</p>
</div>
    </div>

  </div>

  <script src="/js/loader.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>