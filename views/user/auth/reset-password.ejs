<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Reset Password - HypeHub</title>
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body>

  <div class="auth-container">

    <!-- Left Side -->
    <div class="auth-left">
      <div class="auth-left-content">
        <h1>SECURE YOUR <br/><span>ARSENAL.</span></h1>
        <p>Update your credentials to maintain access to the latest drops and exclusive market data.</p>
      </div>
    </div>

    <!-- Right Side -->
    <div class="auth-right">
      <div class="auth-box">

        <a href="/login" class="back-link">← Back to Login</a>
        <h2>Set New Password</h2>
        <p class="subtitle">
          Your new password must be different from previous ones.
        </p>

        <% if (error) { %>
          <div class="error-msg"><%= error %></div>
        <% } %>

        <form action="/reset-password" method="POST">

<div class="form-group">
  <label>NEW PASSWORD</label>
  <div class="input-icon">
    <input type="password" name="newPassword" id="newPassword" placeholder="••••••••"/>
<span class="eye-icon" id="newPassword-icon" onclick="togglePassword('newPassword')" style="pointer-events:all; cursor:pointer;">
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="pointer-events:none;">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
  </svg>
</span>
 </div>
  <small class="hint">Must be at least 8 characters.</small>
</div>

<div class="form-group">
  <label>CONFIRM PASSWORD</label>
  <div class="input-icon">
    <input type="password" name="confirmPassword" id="confirmPassword" placeholder="••••••••"/>
<span class="eye-icon" id="confirmPassword-icon" onclick="togglePassword('confirmPassword')" style="pointer-events:all; cursor:pointer;">
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="pointer-events:none;">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
  </svg>
</span>
  </div>
</div>

          <button type="submit" class="btn-primary">UPDATE PASSWORD →</button>

        </form>

        <p class="redirect-text">
          Need help? <a href="#">Contact Support</a>
        </p>

      </div>
    </div>

  </div>

<script src="/js/main.js"></script>

<script src="/js/loader.js"></script>
</body>
</html>