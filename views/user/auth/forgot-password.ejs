<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Forgot Password - HypeHub</title>
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body>

  <div class="auth-container">

    <!-- Left Side -->
    <div class="auth-left">
      <div class="auth-left-content">
        <h1>RESET YOUR <br/><span>ACCESS.</span></h1>
        <p>Enter your email to receive a recovery OTP.</p>
      </div>
    </div>

    <!-- Right Side -->
    <div class="auth-right">
      <div class="auth-box">

        <h2>Reset Your Access</h2>
        <p class="subtitle">Enter your email to receive a recovery OTP.</p>

        <!-- Error -->
        <% if (error) { %>
          <div class="error-msg"><%= error %></div>
        <% } %>

        <form action="/forgot-password" method="POST">

          <div class="form-group">
            <label>EMAIL ADDRESS</label>
            <div class="input-icon">
              <span>✉</span>
            <input
          type="email"
           name="email"
              placeholder="Enter your registered email"
                value="<%= typeof formData !== 'undefined' ? formData.email || '' : '' %>"/>
            </div>
          </div>

          <button type="submit" class="btn-primary">SEND OTP →</button>

        </form>

        <p class="redirect-text">
          <a href="/login">← Back to Login</a>
        </p>

      </div>
    </div>

  </div>

  <script src="/js/loader.js"></script>
</body>
</html>