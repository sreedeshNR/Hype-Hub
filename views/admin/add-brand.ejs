<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Add Brand - HypeHub Admin</title>
  <link rel="stylesheet" href="/css/admin.css"/>
</head>
<body>

  <div class="admin-container">
    <%- include('partials/sidebar') %>

    <div class="admin-main">

      <div class="breadcrumb">
        <a href="/admin/brands">Brands</a> →
        <span>New Brand</span>
      </div>

      <h2 class="page-title">Add Brand</h2>

      <% if (typeof errors !== 'undefined' && errors.general) { %>
        <div class="error-msg"><%= errors.general %></div>
      <% } %>

      <form action="/admin/brands/add" method="POST" enctype="multipart/form-data">

        <div class="form-card">

          <div class="form-row">
            <!-- Brand Name -->
            <div class="form-group">
              <label>BRAND NAME</label>
              <input
                type="text"
                name="name"
                placeholder="eg: Nike"
                value="<%= typeof formData !== 'undefined' ? formData.name || '' : '' %>"
                oninput="generateSlug(this.value)"
              />
              <% if (typeof errors !== 'undefined' && errors.name) { %>
                <span class="field-error"><%= errors.name %></span>
              <% } %>
            </div>

            <!-- Slug -->
            <div class="form-group">
              <label>BRAND SLUG (AUTO-GENERATED)</label>
              <div class="slug-wrap">
                <input type="text" name="slug" id="brandSlug" placeholder="brand-slug" readonly/>
                <span class="slug-lock">🔒</span>
              </div>
            </div>
          </div>

          <!-- Description -->
          <div class="form-group">
            <label>DESCRIPTION</label>
            <textarea
              name="description"
              rows="4"
              placeholder="Brief description about the brand..."
            ><%= typeof formData !== 'undefined' ? formData.description || '' : '' %></textarea>
            <% if (typeof errors !== 'undefined' && errors.description) { %>
              <span class="field-error"><%= errors.description %></span>
            <% } %>
          </div>

          <!-- Status -->
          <div class="form-group">
            <label>BRAND STATUS</label>
            <select name="isActive">
              <option value="true">Active</option>
              <option value="false">Inactive</option>
            </select>
          </div>

        </div>

        <!-- Brand Logo -->
        <div class="form-card" style="margin-top: 20px;">
          <h3 class="form-card-title">BRAND LOGO</h3>
          <div class="image-upload-area" onclick="document.getElementById('brandLogo').click()">
            <img src="/images/icons/upload.svg" width="40" height="40" alt="Upload" id="uploadIcon"/>
            <img id="imagePreview" src="" alt="Preview" style="display:none; max-width:200px; border-radius:8px;"/>
            <p>Click or drag to upload</p>
            <p class="upload-hint">SVG, PNG, JPG (max. 800×400px)</p>
            <input
              type="file"
              name="image"
              id="brandLogo"
              accept="image/*"
              style="display:none;"
              onchange="previewImage(this)"
            />
          </div>
          <% if (typeof errors !== 'undefined' && errors.logo) { %>
            <span class="field-error"><%= errors.logo %></span>
          <% } %>
        </div>

        <div class="form-actions" style="margin-top: 20px;">
          <a href="/admin/brands" class="btn-cancel">Cancel</a>
          <button type="submit" class="btn-primary">PUBLISH →</button>
        </div>

      </form>
    </div>
  </div>

  <script src="/js/loader.js"></script>
  <script src="/js/main.js"></script>
  <script>
    function generateSlug(name) {
      const slug = name.toLowerCase().trim()
        .replace(/[^a-z0-9\s-]/g, "")
        .replace(/\s+/g, "-");
      document.getElementById("brandSlug").value = slug;
    }

    function previewImage(input) {
      if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = (e) => {
          const preview = document.getElementById("imagePreview");
          const icon = document.getElementById("uploadIcon");
          preview.src = e.target.result;
          preview.style.display = "block";
          icon.style.display = "none";
        };
        reader.readAsDataURL(input.files[0]);
      }
    }
  </script>
</body>
</html>