<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Add Product - HypeHub Admin</title>
  <link rel="stylesheet" href="/css/admin.css"/>
  
  <!-- Cropper.js CSS (CDN) -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" rel="stylesheet">

  <style>
    /* Styling for the image upload boxes */
    .image-upload-container { display: flex; gap: 20px; margin-top: 20px; }
    .upload-box {
      width: 150px; height: 150px; border: 2px dashed #444; border-radius: 12px;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      cursor: pointer; position: relative; overflow: hidden; background: #1a1a24;
    }
    .upload-box img.preview { width: 100%; height: 100%; object-fit: cover; display: none; }
    
    /* Cropper Modal Styling */
    .modal-overlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.8); display: none; justify-content: center; align-items: center; z-index: 1000;
    }
    .cropper-modal { background: #1a1a24; padding: 20px; border-radius: 12px; width: 600px; max-width: 90%; }
    .cropper-container-box { width: 100%; height: 400px; background: #000; margin-bottom: 20px; }
    .modal-actions { display: flex; justify-content: flex-end; gap: 10px; }
  </style>
</head>
<body>

  <div class="admin-container">
    <%- include('partials/sidebar') %>

    <div class="admin-main">
      <div class="breadcrumb">
        <a href="/admin/products">Products</a> → <span>Add New Product</span>
      </div>

      <% if (typeof errors !== 'undefined' && errors.general) { %>
        <div class="error-msg"><%= errors.general %></div>
      <% } %>

      <form action="/admin/products/add" method="POST" enctype="multipart/form-data" id="addProductForm">
        
        <!-- Hidden input to hold our cropped files -->
        <input type="file" id="finalImages" name="images" multiple style="display: none;">

        <!-- 1. PRODUCT INFORMATION -->
        <div class="form-card">
          <h3 class="form-card-title"><span class="icon">ℹ️</span> Product Information</h3>
          
          <div class="form-row" style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 20px;">
            <div class="form-group">
              <label>PRODUCT NAME</label>
              <input type="text" name="productName" placeholder="e.g. Air Jordan 1 Retro High OG" value="<%= typeof formData !== 'undefined' ? formData.productName || '' : '' %>" oninput="generateSlug(this.value)">
              <input type="hidden" name="slug" id="productSlug" value="<%= typeof formData !== 'undefined' ? formData.slug || '' : '' %>">
              <% if (typeof errors !== 'undefined' && errors.productName) { %><span class="field-error"><%= errors.productName %></span><% } %>
            </div>

            <div class="form-group">
              <label>CATEGORY</label>
              <select name="categoryId">
                <option value="">Select</option>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat._id %>" <%= typeof formData !== 'undefined' && formData.categoryId == cat._id ? 'selected' : '' %>><%= cat.name %></option>
                <% }) %>
              </select>
              <% if (typeof errors !== 'undefined' && errors.categoryId) { %><span class="field-error"><%= errors.categoryId %></span><% } %>
            </div>

            <div class="form-group">
              <label>BRAND</label>
              <select name="brandId">
                <option value="">Select</option>
                <% brands.forEach(brand => { %>
                  <option value="<%= brand._id %>" <%= typeof formData !== 'undefined' && formData.brandId == brand._id ? 'selected' : '' %>><%= brand.name %></option>
                <% }) %>
              </select>
              <% if (typeof errors !== 'undefined' && errors.brandId) { %><span class="field-error"><%= errors.brandId %></span><% } %>
            </div>
          </div>

          <div class="form-row" style="display: grid; grid-template-columns: 1fr 3fr; gap: 20px; margin-top: 15px;">
            <div class="form-group">
              <label>GENDER</label>
              <select name="gender">
                <option value="UNISEX" <%= typeof formData !== 'undefined' && formData.gender === 'UNISEX' ? 'selected' : '' %>>Unisex</option>
                <option value="MEN" <%= typeof formData !== 'undefined' && formData.gender === 'MEN' ? 'selected' : '' %>>Men</option>
                <option value="WOMEN" <%= typeof formData !== 'undefined' && formData.gender === 'WOMEN' ? 'selected' : '' %>>Women</option>
              </select>
              <% if (typeof errors !== 'undefined' && errors.gender) { %><span class="field-error"><%= errors.gender %></span><% } %>
            </div>

            <div class="form-group">
              <label>DESCRIPTION</label>
              <textarea name="description" rows="2" placeholder="Describe the heritage, materials..."><%= typeof formData !== 'undefined' ? formData.description || '' : '' %></textarea>
              <% if (typeof errors !== 'undefined' && errors.description) { %><span class="field-error"><%= errors.description %></span><% } %>
            </div>
          </div>
        </div>

        <!-- 2. PRODUCT VARIANTS -->
        <div class="form-card" style="margin-top: 20px;">
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <h3 class="form-card-title"><span class="icon">⬡</span> Product Variants (Initial)</h3>
          </div>

          <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-top: 15px;">
            <div class="form-group">
              <label>COLOR</label>
              <input type="text" name="color" placeholder="e.g. Red/White" value="<%= typeof formData !== 'undefined' ? formData.color || '' : '' %>">
              <% if (typeof errors !== 'undefined' && errors.color) { %><span class="field-error"><%= errors.color %></span><% } %>
            </div>
            <div class="form-group">
              <label>REGULAR PRICE</label>
              <input type="number" name="regularPrice" placeholder="$" value="<%= typeof formData !== 'undefined' ? formData.regularPrice || '' : '' %>">
              <% if (typeof errors !== 'undefined' && errors.regularPrice) { %><span class="field-error"><%= errors.regularPrice %></span><% } %>
            </div>
            <div class="form-group">
              <label>SALE PRICE</label>
              <input type="number" name="salePrice" placeholder="$" value="<%= typeof formData !== 'undefined' ? formData.salePrice || '' : '' %>">
              <% if (typeof errors !== 'undefined' && errors.salePrice) { %><span class="field-error"><%= errors.salePrice %></span><% } %>
            </div>
          </div>

          <!-- Sizes Table -->
          <div class="form-group" style="margin-top: 20px;">
            <label>SIZE & QUANTITY</label>
            <div id="sizeContainer">
              <!-- Default Row -->
              <div class="size-row" style="display: flex; gap: 15px; margin-bottom: 10px; align-items: center;">
                <input type="number" name="size" placeholder="Size (EU)" style="width: 120px;" required>
                <input type="number" name="quantity" placeholder="Qty" style="width: 120px;" required>
                <button type="button" class="btn-cancel" onclick="removeSizeRow(this)" style="padding: 8px 12px;">✕</button>
              </div>
            </div>
            <button type="button" class="btn-secondary" onclick="addSizeRow()" style="margin-top: 10px; font-size: 12px;">+ Add Size</button>
            
            <!-- Inline Size Error Container -->
            <div class="field-error" id="sizeError" style="margin-top: 5px; color: #ff4444;">
              <% if (typeof errors !== 'undefined' && errors.sizes) { %><%= errors.sizes %><% } %>
            </div>
          </div>

          <!-- Image Uploads -->
          <div class="form-group" style="margin-top: 30px;">
            <label>IMAGES (Minimum 3 required)</label>
            
            <!-- Inline Image Error Container -->
            <div class="field-error" id="imageError" style="color: #ff4444; margin-bottom: 10px;">
              <% if (typeof errors !== 'undefined' && errors.images) { %><%= errors.images %><% } %>
            </div>
            
            <div class="image-upload-container">
              <!-- Box 1 -->
              <div class="upload-box" onclick="triggerFileInput(1)">
                <span id="plus-1">+</span>
                <img id="preview-1" class="preview" alt="">
                <input type="file" id="rawFile-1" accept="image/*" style="display: none;" onchange="openCropper(event, 1)">
              </div>
              <!-- Box 2 -->
              <div class="upload-box" onclick="triggerFileInput(2)">
                <span id="plus-2">+</span>
                <img id="preview-2" class="preview" alt="">
                <input type="file" id="rawFile-2" accept="image/*" style="display: none;" onchange="openCropper(event, 2)">
              </div>
              <!-- Box 3 -->
              <div class="upload-box" onclick="triggerFileInput(3)">
                <span id="plus-3">+</span>
                <img id="preview-3" class="preview" alt="">
                <input type="file" id="rawFile-3" accept="image/*" style="display: none;" onchange="openCropper(event, 3)">
              </div>
            </div>
          </div>

        </div>

        <div class="form-actions" style="margin-top: 20px; text-align: right;">
          <a href="/admin/products" class="btn-cancel">DISCARD</a>
          <button type="button" class="btn-primary" onclick="submitForm()">SAVE PRODUCT</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Cropper Modal -->
  <div class="modal-overlay" id="cropperModal">
    <div class="cropper-modal">
      <h3 style="margin-top:0; color:#fff;">Crop Image</h3>
      <div class="cropper-container-box">
        <img id="cropperImage" src="" style="max-width: 100%;">
      </div>
      <div class="modal-actions">
        <button type="button" class="btn-cancel" onclick="closeCropperModal()">Cancel</button>
        <button type="button" class="btn-primary" onclick="confirmCrop()">Crop & Save</button>
      </div>
    </div>
  </div>

  <!-- Scripts -->
  <script src="/js/loader.js"></script>
  <!-- 1. Load Cropper library FIRST -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
  <!-- 2. Load your custom logic SECOND -->
  <script src="/js/main.js"></script>
</body>
</html>